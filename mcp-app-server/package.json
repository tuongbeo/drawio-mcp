{
  "name": "drawio-mcp",
  "version": "2.0.0",
  "description": "Draw.io remote MCP server — TypeScript, Cloudflare Workers, inline diagram rendering",
  "private": true,
  "type": "module",
  "scripts": {
    "build:html": "node --loader ts-node/esm src/build-html.ts",
    "build:tsc": "tsc",
    "build": "npm run build:html && npm run build:tsc",
    "deploy": "npm run build && wrangler deploy",
    "dev:node": "tsx src/index.ts",
    "dev:worker": "wrangler dev",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^0.1.0",
    "@modelcontextprotocol/sdk": "^1.10.0",
    "express": "^4.18.2",
    "fast-xml-parser": "^4.3.6",
    "pako": "^2.1.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240208.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "wrangler": "^3.28.0"
  }
}
